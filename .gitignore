# OS / editor noise
.DS_Store
Thumbs.db
._*
*.swp
*.swo
*~

# Local env files
.env
.env.*
!.env.example

# C/C++ build outputs
build/
dist/
out/
bin/
obj/
target/
*.o
*.obj
*.a
*.so
*.dylib
*.dll
*.exe
*.out
*.d

# CMake / Ninja / Meson outputs
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
compile_commands.json
build.ninja
.ninja_deps
.ninja_log
meson-private/
meson-logs/

# Coverage / profiling / sanitizer artifacts
coverage/
*.gcno
*.gcda
*.gcov
*.profraw
*.profdata
*.stackdump

# Runtime traces / generated artifacts
artifacts/
*.trace
*.trace.json
*.trace.bin
*.fuzz
*.min
*.seed

# Ephemeral diff/patch files
diff.txt
*.diff
*.patch

# Local issue-tracking state
# Keep canonical beads artifacts in git, but ignore local DB/cache/locks.
.beads/*.db
.beads/*.db-shm
.beads/*.db-wal
.beads/*.lock
.beads/last-touched
.beads/*.tmp

# bv (beads viewer) local config and caches
.bv/
.claude/settings.local.json

# Named build directories (cross-compilation / host-specific outputs)
build_*/

# SQLite runtime files
storage.sqlite3
storage.sqlite3-*
*.sqlite3.bak
*.sqlite3.bak-*
*.sqlite3.corrupt-*
*.sqlite3-wal.corrupt-*
